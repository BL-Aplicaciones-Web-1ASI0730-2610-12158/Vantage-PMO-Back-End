POST {{vantagePMO_platform_HostAddress}}/api/v1/tasks
Content-Type: application/json

{
  "boardId": 1,
  "project": "PROJECT::HORIZON",
  "title": "Review deployment checklist",
  "description": "Validate staging rollout steps.",
  "assignee": "Alex Sterling",
  "assigneeAvatar": "AS",
  "assigneeColor": "#3b82f6",
  "status": "To Do",
  "priority": "NORMAL",
  "priorityColor": "#6b7280",
  "completed": false,
  "comments": 0,
  "attachments": 0,
  "dueDate": "2026-06-20",
  "progress": 0,
  "department": "Engineering"
}

